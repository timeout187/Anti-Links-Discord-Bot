# AntiLink Guard OSS - example bot environment configuration
# Copy this file to .env and fill in your values. Never commit your real .env.

# Required: your Discord bot token (Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Required for `pnpm run register-commands`: your application's Client ID
# (Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=

# Optional: a single guild (server) ID to register commands to for local
# development. Guild commands update instantly; global commands (leave this
# blank) can take up to an hour to propagate.
DISCORD_GUILD_ID=

# SQLite is the default, zero-setup storage backend for self-hosting.
DATABASE_SQLITE_PATH=./data/antilink.sqlite

# Log verbosity: trace, debug, info, warn, error, silent
LOG_LEVEL=info
