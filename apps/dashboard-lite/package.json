{
  "name": "@antilink-guard/dashboard-lite",
  "version": "0.1.0",
  "private": true,
  "description": "A minimal, local, read-only dashboard for a self-hosted AntiLink Guard OSS bot.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@antilink-guard/storage": "workspace:*",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
