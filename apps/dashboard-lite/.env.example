# AntiLink Guard OSS dashboard-lite - environment configuration
# Copy this file to .env and adjust as needed.

# Path to the SAME SQLite database file your example-bot instance uses.
DATABASE_SQLITE_PATH=../example-bot/data/antilink.sqlite

# Port to serve the dashboard on. Bind to localhost only in production use -
# this tool has no authentication (see README.md).
PORT=4000
